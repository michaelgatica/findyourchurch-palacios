{
  "firestore": [
    {
      "database": "findyourchurchpal",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ],
  "storage": {
    "rules": "storage.rules"
  },
  "apphosting": [
    {
      "backendId": "community-hub-staging",
      "rootDir": ".",
      "ignore": [
        "node_modules",
        ".git",
        ".next",
        ".env",
        ".env.*",
        "!.env.example",
        "!.env.staging.example",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "playwright-report",
        "test-results"
      ]
    }
  ],
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8180
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
