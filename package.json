{
  "name": "find-my-church-palacios",
  "version": "1.0.0",
  "private": true,
  "description": "Launch-ready church directory and ministry platform for Find Your Church Palacios.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "emulators": "firebase emulators:start",
    "seed:firebase": "tsx scripts/seed-firestore.ts",
    "import:palacios": "tsx scripts/import-palacios-churches.ts",
    "cleanup:demo-data": "tsx scripts/remove-demo-data.ts",
    "cleanup:demo-data:confirm": "tsx scripts/remove-demo-data.ts --confirm",
    "cleanup:test-data": "tsx scripts/remove-workflow-test-data.ts",
    "cleanup:test-data:confirm": "tsx scripts/remove-workflow-test-data.ts --confirm",
    "seed:admin": "tsx scripts/seed-admin-user.ts",
    "test:firebase-submission": "tsx scripts/test-firebase-submission.ts",
    "test:firebase-storage": "tsx scripts/test-firebase-storage.ts",
    "test:email": "tsx scripts/test-email.ts",
    "test:staging-email": "tsx scripts/test-staging-email.ts",
    "process:listing-verifications": "tsx scripts/process-listing-verifications.ts",
    "audit:firebase": "tsx scripts/audit-firebase-data.ts",
    "ops:launch-check": "tsx scripts/ops-launch-check.ts",
    "test:phase3-workflows": "tsx scripts/test-phase3-workflows.ts",
    "test:phase4-workflows": "tsx scripts/test-phase4-workflows.ts",
    "test:directory-routing": "tsx scripts/test-directory-routing.ts",
    "test:event-validation": "tsx scripts/test-event-validation.ts",
    "test:registration-validation": "tsx scripts/test-registration-validation.ts",
    "test:registration-reports": "tsx scripts/test-registration-reports-email.ts",
    "test:registration-scheduler": "tsx scripts/test-registration-scheduler.ts",
    "test:registration-scheduler-security": "tsx scripts/test-registration-scheduler-security.ts",
    "test:platform-launch-readiness": "tsx scripts/test-platform-launch-readiness.ts",
    "test:staging-validation": "tsx scripts/test-staging-validation.ts",
    "test:registration-emulator": "firebase emulators:exec --project demo-find-your-church --only firestore \"tsx scripts/test-registration-emulator.ts\"",
    "test:firestore-rules": "firebase emulators:exec --project demo-find-your-church --only firestore \"tsx scripts/test-firestore-rules.ts\"",
    "test:storage-rules": "firebase emulators:exec --project demo-find-your-church --only storage \"tsx scripts/test-storage-rules.ts\"",
    "test:staging-storage": "tsx scripts/test-staging-storage.ts",
    "test:hosted-staging": "tsx scripts/test-hosted-staging.ts",
    "test:staging-scheduler-hosted": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-staging-scheduler-smoke.ps1",
    "test:staging-admin-ops": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-staging-admin-ops-smoke.ps1",
    "test:event-security": "firebase emulators:exec --project demo-find-your-church --only firestore,storage,auth \"tsx scripts/test-firestore-rules.ts && tsx scripts/test-storage-rules.ts\"",
    "process:registration-jobs": "tsx scripts/process-registration-jobs.ts",
    "configure:staging-scheduler": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/configure-staging-scheduler.ps1",
    "certify:staging-scheduler": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-staging-scheduler-certification.ps1",
    "seed:community-hub-staging": "tsx scripts/seed-community-hub-staging.ts",
    "rotate:community-hub-staging-passwords": "tsx scripts/rotate-staging-qa-passwords.ts",
    "reset:community-hub-staging": "tsx scripts/reset-community-hub-staging.ts"
  },
  "keywords": [
    "ministry",
    "church-directory",
    "nextjs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "image-size": "^2.0.2",
    "leaflet": "^1.9.4",
    "next": "^15.5.15",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "firebase-tools": "^15.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
