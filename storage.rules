rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAcceptedChurchImageUpload() {
      return request.resource != null &&
        request.resource.size <= 8 * 1024 * 1024 &&
        request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    match /church-submissions/{submissionId}/logo/{fileName} {
      allow read: if false;
      allow write: if false;
      // Current public submission uploads are handled server-side by the Firebase
      // Admin SDK, so direct client writes stay disabled for now.
      // TODO: If uploads ever move client-side, require isSignedIn(),
      // isAcceptedChurchImageUpload(), and a verified submission ownership flow.
    }

    match /church-submissions/{submissionId}/photos/{fileName} {
      allow read: if false;
      allow write: if false;
    }

    match /churches/{churchId}/logo/{fileName} {
      allow read: if true;
      allow write: if false;
      // Phase 4 representative uploads are handled by trusted server actions
      // through the Firebase Admin SDK, so direct browser uploads remain disabled.
      // TODO before any direct client uploads: enforce representative/admin auth,
      // church ownership checks, and keep isAcceptedChurchImageUpload().
    }

    match /churches/{churchId}/photos/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
