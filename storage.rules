rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /church-submissions/{submissionId}/logo/{fileName} {
      allow read: if false;
      allow write: if false;
      // Submission uploads are authorized, validated, and stored only by trusted
      // Firebase Admin operations. Browser access is intentionally unavailable.
    }

    match /church-submissions/{submissionId}/photos/{fileName} {
      allow read: if false;
      allow write: if false;
    }

    match /churches/{churchId}/logo/{fileName} {
      allow read: if true;
      allow write: if false;
      // Representative uploads are authorized, validated, and stored by trusted
      // server actions. Direct browser writes are intentionally unavailable.
    }

    match /churches/{churchId}/photos/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /churches/{churchId}/events/{eventId}/flyer/{fileName} {
      allow get: if true;
      allow list: if false;
      allow write: if false;
      // Server-side flyer upload enforces JPG/PNG/WebP, 8 MB maximum, safe
      // generated filenames, dimension checks, and church/event ownership.
    }

    match /private/event-exports/{churchId}/{eventId}/{fileName} {
      allow read, write: if false;
      // Reports are created and delivered by trusted server operations only.
      // Public flyer access never applies to this private path.
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
