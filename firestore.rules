rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserRole() {
      return hasUserProfile()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return currentUserRole() == 'admin';
    }

    function isOwnerOfUserScopedRecord(fieldName) {
      return signedIn() && resource.data[fieldName] == request.auth.uid;
    }

    match /churches/{churchId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
      // Representative listing changes are handled through trusted server actions
      // and the Firebase Admin SDK in Phase 4, so direct client writes remain disabled.
    }

    match /churchSubmissions/{submissionId} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && userId == request.auth.uid);
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
      // User profile creation and sync are handled through trusted server routes
      // and the Firebase Admin SDK to prevent self-assigned role escalation.
    }

    match /churchRepresentatives/{representativeId} {
      allow read: if isAdmin() || isOwnerOfUserScopedRecord('userId');
      allow write: if isAdmin();
      // TODO: If representative document list queries move client-side, require
      // query constraints that scope results to request.auth.uid.
    }

    match /churchClaimRequests/{claimRequestId} {
      allow create: if isAdmin();
      allow read: if isAdmin() || isOwnerOfUserScopedRecord('requesterUserId');
      allow update, delete: if isAdmin();
      // Public claim submissions are routed through trusted server actions
      // and the Firebase Admin SDK, so direct client writes stay disabled.
    }

    match /churchUpdateRequests/{updateRequestId} {
      allow read: if isAdmin() || isOwnerOfUserScopedRecord('submittedByUserId');
      allow write: if isAdmin();
    }

    match /ownershipTransferRequests/{transferRequestId} {
      allow read: if isAdmin() || isOwnerOfUserScopedRecord('requestedByUserId');
      allow write: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      // Phase 4 representative message reads/writes are routed through trusted
      // server actions, so direct client access stays disabled for now.
    }

    match /auditLogs/{auditLogId} {
      allow read, write: if isAdmin();
    }

    match /emailLogs/{emailLogId} {
      allow read, write: if isAdmin();
    }

    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
